version = "3.10.7"      # scalafmt version
runner.dialect = scala213

maxColumn = 100
indent.main = 2
indent.callSite = 2
indent.defnSite = 2

align.preset = more    # Aligns assignments and arrows for readability
danglingParentheses.preset = true
rewrite.rules = [SortModifiers, PreferCurlyFors, Imports]
rewrite.imports.sort = scalastyle
